# Application
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1
ALLOWED_ORIGINS=*
LOG_LEVEL=log

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=7d

# Database
DATABASE_URL="file:./prisma/dev.db"

# Scraping
SCRAPE_CONCURRENCY=2
SCRAPE_DELAY_MS=1500
SCRAPE_TIMEOUT_MS=15000

# Worlds
TRACKED_WORLDS=Calmera

# Scheduler — cron expressions
ONLINE_JOB_CRON=*/5 * * * *
HIGHSCORES_JOB_CRON=0 */6 * * *
CHARACTER_REFRESH_CRON=0 2 * * *
DAILY_METRICS_CRON=30 2 * * *
DISCOVERY_RECONCILIATION_CRON=0 3 * * *
