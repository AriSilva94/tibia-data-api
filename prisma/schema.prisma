generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model World {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  region          String?
  pvpType         String?
  isTracked       Boolean   @default(false)
  lastOnlineCount Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("worlds")
}
